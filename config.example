# Welcome.sh Configuration File
# 
# This is an example configuration file for welcome.sh
# Copy to ~/.config/welcome.sh/config and customize as needed
#
# Installation location: ~/.config/welcome.sh/config

# ============================================================================
# Display Options
# ============================================================================

# Show fastfetch system information
# Default: true
SHOW_FASTFETCH=true

# Show weather information from wttr.in
# Default: true
SHOW_WEATHER=true

# Show your public IP address
# Default: true
SHOW_PUBLIC_IP=true

# Show your private/local IP address
# Default: false
SHOW_PRIVATE_IP=false

# Show uptime and load average
# Default: true
SHOW_UPTIME=true

# Show system metrics (disk usage, memory, CPU temp, top CPU process)
# Default: true
SHOW_SYSTEM_METRICS=true

# Show ASCII art banner at the top
# Default: false
SHOW_ASCII_ART=false

# Quiet mode - reduces output for faster loading
# Default: false
QUIET_MODE=false

# ============================================================================
# Location Settings
# ============================================================================

# Weather location for wttr.in
# Format: "City+Name" or "City" (use + for spaces)
# Leave empty or comment out to use default (New+York)
# Examples:
#   WEATHER_LOCATION="New+York"
#   WEATHER_LOCATION="London"
#   WEATHER_LOCATION="Tokyo"
WEATHER_LOCATION=""

# Weather display format for wttr.in
# See https://wttr.in/:help for the full list of format and configuration options
# Common options: 1 (current weather), 2 (current+today+tomorrow),
#   3 (weather with city name), 4 (weather only, no city name)
# Note: The value is passed to wttr.in as-is, including casing
# Default: 3
WEATHER_FORMAT="3"

# Custom greeting message displayed at the end
# Default varies by language (e.g., "You are good to go for Whiskey, Tango, Foxtrot!")
# Set to override the default greeting in any language
GREETING=""

# ============================================================================
# Performance Settings
# ============================================================================

# Cache timeout in seconds for public IP and weather data
# Reduces external API calls and improves load time
# Default: 3600 (1 hour)
CACHE_TIMEOUT=3600

# Request timeout for external API calls (curl)
# Prevents hanging on slow connections
# Default: 3 (seconds)
REQUEST_TIMEOUT=3
